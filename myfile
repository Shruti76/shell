### Step 5: Integration with Components

**Time Required:** 2 hours  
**Complexity:** Medium

```javascript
// File: frontend/src/pages/GitHubCodespacesDashboard.jsx

export function GitHubCodespacesDashboard() {
  const { user } = useAuth();
  const [hasGitHub, setHasGitHub] = useState(false);
  
  useEffect(() => {
    // Check if user has GitHub token
    if (user?.githubToken) {
      setHasGitHub(true);
    }
  }, [user]);
  
  if (!hasGitHub) {
    return (
      <div className="connect-github">
        <h2>Connect Your GitHub Account</h2>
        <p>To access GitHub Codespaces, connect your GitHub account</p>
        <GitHubOAuthButton onConnect={() => setHasGitHub(true)} />
      </div>
    );
  }
  
  // Show dashboard with codespaces...
}
```

