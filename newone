## 💾 Database Schema

```sql
-- IDE Sessions
CREATE TABLE ide_sessions (
  id SERIAL PRIMARY KEY,
  user_id INT NOT NULL REFERENCES users(id),
  repository_id INT NOT NULL REFERENCES repositories(id),
  workspace_path VARCHAR(255),
  current_branch VARCHAR(100),
  opened_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  closed_at TIMESTAMP,
  active BOOLEAN DEFAULT true,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Execution Logs
CREATE TABLE execution_logs (
  id SERIAL PRIMARY KEY,
  ide_session_id INT REFERENCES ide_sessions(id),
  command VARCHAR(500),
  runtime VARCHAR(50), -- python3.11, node18, maven39, etc.
  output TEXT,
  exit_code INT,
  duration FLOAT, -- seconds
  started_at TIMESTAMP,
  completed_at TIMESTAMP,
  container_id VARCHAR(255),
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Validation Requests (Enhanced)
CREATE TABLE validation_requests (
  id SERIAL PRIMARY KEY,
  user_id INT NOT NULL REFERENCES users(id),
  repository_id INT NOT NULL REFERENCES repositories(id),
  ide_session_id INT REFERENCES ide_sessions(id),
  commit_message TEXT,
  status VARCHAR(50), -- pending, in_progress, passed, failed
  security_scan JSONB,
  dependency_check JSONB,
  test_results JSONB,
  code_quality JSONB,
  pr_id INT,
  pr_url VARCHAR(255),
  started_at TIMESTAMP,
  completed_at TIMESTAMP,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- File Changes (Track IDE edits)
CREATE TABLE file_changes (
  id SERIAL PRIMARY KEY,
  ide_session_id INT REFERENCES ide_sessions(id),
  file_path VARCHAR(255),
  change_type VARCHAR(20), -- created, modified, deleted
  old_content TEXT,
  new_content TEXT,
  changed_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Terminal History
CREATE TABLE terminal_history (
  id SERIAL PRIMARY KEY,
  ide_session_id INT REFERENCES ide_sessions(id),
  command VARCHAR(500),
  timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
