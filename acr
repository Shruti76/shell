File: `.devcontainer/post-create.sh`

```bash
#!/bin/bash
set -e

echo "🚀 Setting up CIMP Portal development environment..."

# Login to ACR
echo "📦 Logging into Azure Container Registry..."
echo "$ACR_PASSWORD" | docker login -u "$ACR_USERNAME" --password-stdin "$ACR_LOGIN_SERVER"

# Pull and tag backend image
echo "📥 Pulling API image from ACR..."
docker pull "$ACR_LOGIN_SERVER/cimp-api:latest"
docker tag "$ACR_LOGIN_SERVER/cimp-api:latest" cimp-api:latest

# Pull and tag Blazor frontend image
echo "📥 Pulling Blazor image from ACR..."
docker pull "$ACR_LOGIN_SERVER/cimp-blazor:latest"
docker tag "$ACR_LOGIN_SERVER/cimp-blazor:latest" cimp-blazor:latest

# Pull database image
echo "📥 Pulling database image from ACR..."
docker pull "$ACR_LOGIN_SERVER/cimp-postgres:latest"
docker tag "$ACR_LOGIN_SERVER/cimp-postgres:latest" cimp-postgres:latest

# Start services using docker-compose
echo "🐳 Starting Docker services..."
cd /workspace
docker-compose up -d

# Install dependencies for Node.js frontend (if using React)
if [ -f "frontend/package.json" ]; then
  echo "📚 Installing Node.js dependencies..."
  cd frontend
  npm ci  # Use ci instead of install for reproducible builds
  cd ..
fi

# Install dependencies for .NET backend (if using .NET)
if [ -f "CIMPPortal.Api/CIMPPortal.Api.csproj" ]; then
  echo "📚 Installing .NET dependencies..."
  dotnet restore CIMPPortal.Api/CIMPPortal.Api.csproj
  dotnet restore CIMPPortal.Blazor/CIMPPortal.Blazor.csproj
fi

# Run database migrations
echo "🗄️ Running database migrations..."
# Add your migration commands here

echo "✅ Environment setup complete!"
echo ""
echo "Available services:"
echo "  • Frontend: http://localhost:3000"
echo "  • Backend API: http://localhost:3001"
echo "  • Database: localhost:5432"
echo ""
echo "Run 'docker-compose logs -f' to see logs"
