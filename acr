## GitHub Actions: Build & Push to ACR

File: `.github/workflows/build-acr.yml`

```yaml
name: Build and Push to ACR

on:
  push:
    branches:
      - main
      - develop
    paths:
      - 'CIMPPortal.Api/**'
      - 'CIMPPortal.Blazor/**'
      - 'Dockerfile*'
      - '.github/workflows/build-acr.yml'
  pull_request:
    branches:
      - main
      - develop

env:
  REGISTRY_LOGIN_SERVER: ${{ secrets.ACR_LOGIN_SERVER }}
  REGISTRY_USERNAME: ${{ secrets.ACR_USERNAME }}
  REGISTRY_PASSWORD: ${{ secrets.ACR_PASSWORD }}
  REGISTRY_NAME: ${{ secrets.ACR_REGISTRY_NAME }}
  IMAGE_NAME: cimp-api
  IMAGE_NAME_BLAZOR: cimp-blazor

jobs:
  build-and-push:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v3
        with:
          fetch-depth: 0
      
      - name: Get version
        id: version
        run: |
          VERSION=$(git describe --tags --always --dirty)
          echo "version=$VERSION" >> $GITHUB_OUTPUT
          echo "📦 Building version: $VERSION"
      
      - name: Login to ACR
        run: |
          echo "${{ env.REGISTRY_PASSWORD }}" | \
          docker login -u "${{ env.REGISTRY_USERNAME }}" \
          --password-stdin "${{ env.REGISTRY_LOGIN_SERVER }}"
      
      - name: Build API Docker image
        run: |
          docker build \
            -f CIMPPortal.Api/Dockerfile \
            -t ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME }}:${{ steps.version.outputs.version }} \
            -t ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME }}:latest \
            --cache-from ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME }}:latest \
            .
      
      - name: Push API image to ACR
        run: |
          docker push ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME }}:${{ steps.version.outputs.version }}
          docker push ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME }}:latest
      
      - name: Build Blazor Docker image
        run: |
          docker build \
            -f CIMPPortal.Blazor/Dockerfile \
            -t ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME_BLAZOR }}:${{ steps.version.outputs.version }} \
            -t ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME_BLAZOR }}:latest \
            --cache-from ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME_BLAZOR }}:latest \
            .
      
      - name: Push Blazor image to ACR
        run: |
          docker push ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME_BLAZOR }}:${{ steps.version.outputs.version }}
          docker push ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME_BLAZOR }}:latest
      
      - name: Scan images for vulnerabilities
        run: |
          az acr scan \
            --registry ${{ env.REGISTRY_NAME }} \
            --image ${{ env.IMAGE_NAME }}:${{ steps.version.outputs.version }}
          
          az acr scan \
            --registry ${{ env.REGISTRY_NAME }} \
            --image ${{ env.IMAGE_NAME_BLAZOR }}:${{ steps.version.outputs.version }}
      
      - name: Create deployment summary
        run: |
          echo "## ✅ ACR Build Complete" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "### Images Built" >> $GITHUB_STEP_SUMMARY
          echo "- \`${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME }}:${{ steps.version.outputs.version }}\`" >> $GITHUB_STEP_SUMMARY
          echo "- \`${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME_BLAZOR }}:${{ steps.version.outputs.version }}\`" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "### Available in Codespaces" >> $GITHUB_STEP_SUMMARY
          echo "Images are now available for GitHub Codespaces to pull:" >> $GITHUB_STEP_SUMMARY
          echo "\`\`\`bash" >> $GITHUB_STEP_SUMMARY
          echo "docker pull ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME }}:${{ steps.version.outputs.version }}" >> $GITHUB_STEP_SUMMARY
          echo "docker pull ${{ env.REGISTRY_LOGIN_SERVER }}/${{ env.IMAGE_NAME_BLAZOR }}:${{ steps.version.outputs.version }}" >> $GITHUB_STEP_SUMMARY
          echo "\`\`\`" >> $GITHUB_STEP_SUMMARY
      
      - name: Logout from ACR
        if: always()
        run: docker logout "${{ env.REGISTRY_LOGIN_SERVER }}"
```

